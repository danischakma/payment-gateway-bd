# PostgreSQL Database URL from Render
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin Panel Secret Token (change this to a strong random string)
ADMIN_TOKEN=your-super-secret-admin-token-here

# Base URL of your Render deployment (no trailing slash)
BASE_URL=https://your-app-name.onrender.com

# Port (Render sets this automatically)
PORT=3000

# Allowed origins for CORS (comma-separated, your InfinityFree or other site URLs)
ALLOWED_ORIGINS=https://yoursite.infinityfreeapp.com,https://yourdomain.com

# bKash merchant number
BKASH_NUMBER=01XXXXXXXXX

# Nagad merchant number
NAGAD_NUMBER=01XXXXXXXXX
